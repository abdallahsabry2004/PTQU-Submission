}

async function updateGroupSelect(){
  const cid=document.getElementById('m_acourse').value;
  if(!cid)return;
  const rows=await DB.get('courses',`?id=eq.${cid}`);const c=rows[0];
  const sel=document.getElementById('m_agroup');if(!sel)return;
  sel.innerHTML='<option value="">اختر المجموعة</option>'+((c&&c.groups)||[]).map(g=>`<option value="${g.id}">${g.name}</option>`).join('');
}

async function addAssignment(){
  const title=document.getElementById('m_atitle').value.trim();
  const desc=document.getElementById('m_adesc').value.trim();
  const courseId=document.getElementById('m_acourse').value;
  const deadline=document.getElementById('m_adeadline').value;
  const targetType=document.getElementById('m_atarget').value;
  const targetGroupId=document.getElementById('m_agroup')?document.getElementById('m_agroup').value:'';
  const maxSize=document.getElementById('m_asize').value;
  const allowedTypes=document.getElementById('m_atypes').value;
  if(!title||!courseId)return toast('أدخل العنوان واختر المقرر','error');
  if(targetType==='group'&&!targetGroupId)return toast('اختر المجموعة','error');
  loading(true);
  const rows=await DB.get('courses',`?id=eq.${courseId}`);const c=rows[0];
  const g=targetType==='group'?(c.groups||[]).find(x=>x.id===targetGroupId):null;
  const now=new Date().toLocaleString('ar-EG');
  const a={id:'a'+Date.now(),title,description:desc,course_id:courseId,deadline,
    target_type:targetType,target_group_id:targetGroupId,target_group:g?g.name:'',
    max_size:maxSize,allowed_types:allowedTypes,status:'open',created_at:now};
  await DB.insert('assignments',a);
  const targetStudents=targetType==='all'?c.students:(g?g.members:[]);
  for(const sid of targetStudents){
    await DB.insert('notifications',{
      id:'n'+Date.now()+Math.random(),student_id:sid,type:'assignment',is_read:false,
      title:'📝 طلب تسليم جديد: '+title,
      body:`المقرر: ${c.name} · الموعد: ${deadline||'مفتوح'}`,
      created_at:now
    });
  }
  loading(false);closeModal();toast('تم إرسال الطلب','success');navigate('assignments');
}

async function toggleAssignmentStatus(id,current){
  loading(true);
  await DB.update('assignments',`?id=eq.${id}`,{status:current==='open'?'closed':'open'});
  loading(false);toast('تم تغيير الحالة','success');navigate('assignments');
}

async function deleteAssignment(id){
  if(!confirm('سيتم حذف الطلب وجميع تسليماته'))return;
  loading(true);
  await DB.delete('assignments',`?id=eq.${id}`);
  await DB.delete('submissions',`?assignment_id=eq.${id}`);
  loading(false);toast('تم الحذف','success');navigate('assignments');
}

async function showSubmitModal(aid){
  const rows=await DB.get('assignments',`?id=eq.${aid}`);const a=rows[0];
  showModal(`<div class="modal-title">📤 رفع التسليم</div>
    <div style="background:var(--surface2);border-radius:8px;padding:12px;margin-bottom:16px">
      <div class="assign-detail-row"><span class="assign-detail-lbl">الطلب:</span><span class="assign-detail-val">${a.title}</span></div>
      ${a.deadline?`<div class="assign-detail-row"><span class="assign-detail-lbl">الموعد:</span><span class="assign-detail-val">${a.deadline}</span></div>`:''}
      ${a.allowed_types?`<div class="assign-detail-row"><span class="assign-detail-lbl">الأنواع:</span><span class="assign-detail-val">${a.allowed_types}</span></div>`:''}
    </div>
    <div class="form-group"><label>ملاحظات (اختياري)</label><textarea id="m_snotes"></textarea></div>
    <div style="border:2px dashed var(--border);border-radius:10px;padding:28px;text-align:center;cursor:pointer;background:var(--surface2)"
      onclick="document.getElementById('fileIn').click()"
      ondragover="event.preventDefault();this.style.borderColor='var(--accent)'"
      ondragleave="this.style.borderColor='var(--border)'"
      ondrop="handleDrop(event)">
      <div style="font-size:32px;margin-bottom:8px">📁</div>
      <div style="font-size:13px;color:var(--text2)">اضغط لاختيار ملف أو اسحبه هنا</div>
      <input type="file" id="fileIn" style="display:none" onchange="handleFileSelect(this)" />
    </div>
    <div id="filePreview"></div>
    <div class="modal-footer"><button class="btn btn-ghost" onclick="closeModal()">إلغاء</button>
    <button class="btn btn-primary" onclick="submitAssignment('${aid}')">رفع التسليم</button></div>`);
}

let selectedFile=null;
function handleFileSelect(inp){
  selectedFile=inp.files[0];
  if(selectedFile)document.getElementById('filePreview').innerHTML=`<div class="file-preview"><span>📄 ${selectedFile.name}</span><span style="color:var(--text2)">${(selectedFile.size/1024).toFixed(1)} KB</span></div>`;
}
function handleDrop(e){
  e.preventDefault();selectedFile=e.dataTransfer.files[0];
  if(selectedFile)document.getElementById('filePreview').innerHTML=`<div class="file-preview"><span>📄 ${selectedFile.name}</span><span>${(selectedFile.size/1024).toFixed(1)} KB</span></div>`;
}

async function submitAssignment(aid){
  if(!selectedFile)return toast('اختر ملفاً أولاً','error');
  const notes=document.getElementById('m_snotes').value;
  const reader=new FileReader();
  reader.onload=async function(e){
    loading(true);
    // حذف التسليم القديم "resubmit" إن وجد
    const old=await DB.get('submissions',`?assignment_id=eq.${aid}&student_id=eq.${currentUser.id}&status=eq.resubmit`);
    for(const o of old)await DB.delete('submissions',`?id=eq.${o.id}`);
    await DB.insert('submissions',{
      id:'s'+Date.now(),assignment_id:aid,student_id:currentUser.id,
      file_name:selectedFile.name,file_data:e.target.result,
      notes,status:'pending',submitted_at:new Date().toLocaleString('ar-EG')
    });
    loading(false);selectedFile=null;closeModal();toast('تم رفع التسليم بنجاح','success');navigate('myAssignments');
  };
  reader.readAsDataURL(selectedFile);
}

async function reviewSubmission(id,action){
  loading(true);
  await DB.update('submissions',`?id=eq.${id}`,{status:action});
  const rows=await DB.get('submissions',`?id=eq.${id}`);const s=rows[0];
  const aRows=await DB.get('assignments',`?id=eq.${s.assignment_id}`);const a=aRows[0];
  await DB.insert('notifications',{
    id:'n'+Date.now(),student_id:s.student_id,type:'review',is_read:false,
    title:{accepted:'✅ تم قبول تسليمك',rejected:'❌ تم رفض تسليمك',resubmit:'⚠️ مطلوب إعادة التسليم'}[action],
    body:`للطلب: ${a?a.title:'—'}`,created_at:new Date().toLocaleString('ar-EG')
  });
  loading(false);toast('تم التحديث','success');navigate('submissions');
}

async function downloadSubmission(id,fileName,_){
  loading(true);
  const rows=await DB.get('submissions',`?id=eq.${id}`);
  loading(false);
  const s=rows[0];if(!s||!s.file_data){toast('لا يوجد ملف','error');return;}
  const a=document.createElement('a');a.href=s.file_data;a.download=s.file_name||fileName||'submission';a.click();
}

async function downloadAllSubmissions(){
  loading(true);
  const submissions=await DB.get('submissions');
  loading(false);
  if(!submissions.length){toast('لا توجد تسليمات','error');return;}
  submissions.forEach((s,i)=>{setTimeout(()=>{if(s.file_data){const a=document.createElement('a');a.href=s.file_data;a.download=s.file_name||'submission_'+i;a.click();}},i*400);});
  toast('جاري تحميل جميع التسليمات...','info');
}

async function deleteSubmission(id){
  if(!confirm('هل تريد حذف هذا التسليم نهائياً؟'))return;
  loading(true);
  await DB.delete('submissions',`?id=eq.${id}`);
  loading(false);toast('تم الحذف','success');navigate('submissions');
}

async function saveAdminSettings(){
  const email=document.getElementById('adminEmail').value;
  const np=document.getElementById('adminNewPass').value;
  const cp=document.getElementById('adminConfPass').value;
  if(np&&np!==cp)return toast('كلمتا المرور غير متطابقتين','error');
  const data={email};if(np)data.pass=np;
  loading(true);
  await DB.update('admin',`?id=eq.${currentUser.id}`,data);
  currentUser={...currentUser,...data};
  loading(false);toast('تم الحفظ','success');
}

async function saveStudentProfile(){
  const email=document.getElementById('stEmail').value;
  const np=document.getElementById('stNewPass').value;
  const cp=document.getElementById('stConfPass').value;
  if(np&&np!==cp)return toast('كلمتا المرور غير متطابقتين','error');
  const data={email};if(np)data.pass=np;
  loading(true);
  await DB.update('students',`?id=eq.${currentUser.id}`,data);
  currentUser={...currentUser,...data};
  loading(false);toast('تم الحفظ','success');
}

function showChangePassModal(){
  showModal(`<div class="modal-title">🔑 تغيير كلمة المرور</div>
    <div class="form-group"><label>كلمة المرور الجديدة</label><input type="password" id="cp_new" /></div>
    <div class="form-group"><label>تأكيد كلمة المرور</label><input type="password" id="cp_conf" /></div>
    <div class="modal-footer"><button class="btn btn-ghost" onclick="closeModal()">إلغاء</button>
    <button class="btn btn-primary" onclick="changePass()">تغيير</button></div>`);
}

async function changePass(){
  const np=document.getElementById('cp_new').value;const cp=document.getElementById('cp_conf').value;
  if(!np)return toast('أدخل كلمة المرور','error');
  if(np!==cp)return toast('كلمتا المرور غير متطابقتين','error');
  loading(true);
  if(currentRole==='admin'){await DB.update('admin',`?id=eq.${currentUser.id}`,{pass:np});}
  else{await DB.update('students',`?id=eq.${currentUser.id}`,{pass:np});}
  currentUser={...currentUser,pass:np};
  loading(false);closeModal();toast('تم تغيير كلمة المرور','success');
}

function showForgotModal(){
  showModal(`<div class="modal-title">🔑 استعادة كلمة المرور</div>
    <p style="font-size:13px;color:var(--text2);margin-bottom:16px">أدخل بريدك الإلكتروني المسجل</p>
    <div class="form-group"><label>البريد الإلكتروني</label><input type="email" id="fg_email" /></div>
    <div class="modal-footer"><button class="btn btn-ghost" onclick="closeModal()">إلغاء</button>
    <button class="btn btn-primary" onclick="forgotPass()">إرسال</button></div>`);
}

async function forgotPass(){
  const email=document.getElementById('fg_email').value.trim();
  if(!email)return toast('أدخل البريد الإلكتروني','error');
  loading(true);
  const students=await DB.get('students',`?email=eq.${email}`);
  const adm=await DB.get('admin',`?email=eq.${email}`);
  loading(false);
  if(!students.length&&!adm.length)return toast('البريد غير مسجل في النظام','error');
  toast('تم إرسال رابط الاستعادة إلى بريدك','info');closeModal();
}

function toast(msg,type='info'){
  const wrap=document.getElementById('toastWrap');const t=document.createElement('div');
  t.className=`toast toast-${type}`;t.textContent=msg;wrap.appendChild(t);
  setTimeout(()=>t.remove(),3000);
}
</script>
