async function renderStudentAssignments(){
  const [assignments,courses,submissions]=await Promise.all([
    DB.get('assignments'),DB.get('courses'),DB.get('submissions')
  ]);
  const myCourses=courses.filter(c=>(c.students||[]).includes(currentUser.id));
  const myCourseIds=myCourses.map(c=>c.id);
  const myGroupIds=myCourses.flatMap(c=>(c.groups||[]).filter(g=>(g.members||[]).includes(currentUser.id)).map(g=>g.id));
  const myAssignments=assignments.filter(a=>{
    if(!myCourseIds.includes(a.course_id))return false;
    if(a.target_type==='all')return true;
    if(a.target_type==='group')return myGroupIds.includes(a.target_group_id);
    return false;
  });
  if(!myAssignments.length)return `<div class="card"><p style="text-align:center;color:var(--text2);padding:24px">📭 لا توجد طلبات تسليم حالياً</p></div>`;
  return `<div style="display:grid;gap:12px">${myAssignments.map(a=>{
    const c=courses.find(x=>x.id===a.course_id);
    const allSubs=submissions.filter(s=>s.assignment_id===a.id&&s.student_id===currentUser.id);
    const mySub=allSubs.find(s=>s.status!=='rejected');
    const isResubmit=allSubs.find(s=>s.status==='resubmit');
    const canSubmit=a.status==='open'&&(!mySub||isResubmit);
    return `<div class="card" style="margin:0">
      <div style="display:flex;align-items:flex-start;gap:10px">
        <div style="flex:1"><div style="font-weight:700;font-size:15px;color:var(--primary)">${a.title}</div>
        <div style="font-size:12px;color:var(--text2);margin-top:3px">${c?c.name:'—'}</div>
        ${a.description?`<div style="font-size:13px;color:var(--text);margin-top:8px">${a.description}</div>`:''}
        <div style="margin-top:8px;font-size:12px;color:var(--text2)">📅 الموعد: <strong>${a.deadline||'مفتوح'}</strong>
        ${a.max_size?` · 📦 الحجم الأقصى: ${a.max_size} MB`:''}
        ${a.allowed_types?` · 📄 الأنواع: ${a.allowed_types}`:''}</div>
        ${mySub&&!isResubmit?`<div style="margin-top:8px"><span class="badge badge-${mySub.status==='accepted'?'success':mySub.status==='pending'?'info':'warn'}">حالة تسليمك: ${{pending:'قيد المراجعة',accepted:'مقبول',resubmit:'يلزم إعادة'}[mySub.status]||mySub.status}</span></div>`:''}
        ${isResubmit?`<div style="margin-top:8px"><span class="badge badge-warn">⚠️ مطلوب إعادة التسليم</span></div>`:''}</div>
        <span class="badge badge-${a.status==='open'?'success':'gray'}">${a.status==='open'?'مفتوح':'مغلق'}</span>
      </div>
      ${canSubmit?`<div style="margin-top:14px;border-top:0.5px solid var(--border);padding-top:14px">
        <button class="btn btn-primary btn-sm" onclick="showSubmitModal('${a.id}')">📤 ${isResubmit?'إعادة التسليم':'رفع التسليم'}</button></div>`:''}
    </div>`;
  }).join('')}</div>`;
}

async function renderStudentSubmissions(){
  const [submissions,assignments,courses]=await Promise.all([
    DB.get('submissions',`?student_id=eq.${currentUser.id}`),
    DB.get('assignments'),DB.get('courses')
  ]);
  const byCourse={};
  submissions.forEach(s=>{
    const a=assignments.find(x=>x.id===s.assignment_id);if(!a)return;
    const c=courses.find(x=>x.id===a.course_id);const key=c?c.id:'other';
    if(!byCourse[key])byCourse[key]={name:c?c.name:'غير محدد',items:[]};
    byCourse[key].items.push({...s,assignTitle:a.title});
