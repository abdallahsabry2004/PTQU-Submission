      <td style="font-size:12px;direction:ltr;text-align:right">${s.submitted_at||''}</td>
      <td><span class="badge badge-${s.status==='accepted'?'success':s.status==='rejected'?'danger':s.status==='resubmit'?'warn':'info'}">${{pending:'قيد المراجعة',accepted:'مقبول',rejected:'مرفوض',resubmit:'إعادة تسليم'}[s.status]||s.status}</span></td>
      <td><button class="btn btn-ghost btn-sm" onclick="downloadSubmission('${s.id}','${s.file_name||''}','')">⬇️ تحميل</button></td>
