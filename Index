<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>منصة تسليم الأبحاث</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700&family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet" />
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
--primary:#1a3c5e;--primary-light:#2563a8;--accent:#e8a020;--accent-light:#f5c55a;
--danger:#c0392b;--success:#1a7a4a;--warn:#b7600a;
--bg:#f4f6fa;--surface:#fff;--surface2:#f0f4fb;--border:#d0d8e8;
--text:#1a2236;--text2:#4a5672;--text3:#8a96b0;
--radius:10px;--shadow:0 2px 12px rgba(26,60,94,0.10)
}
body{font-family:'Cairo',sans-serif;background:var(--bg);color:var(--text);direction:rtl;min-height:100vh}
.hidden{display:none!important}
.page{padding:0;min-height:100vh}
#loginPage{background:linear-gradient(135deg,#1a3c5e 0%,#2563a8 60%,#1a3c5e 100%);display:flex;align-items:center;justify-content:center;min-height:100vh}
.login-card{background:var(--surface);border-radius:18px;padding:40px 36px;width:380px;box-shadow:0 8px 40px rgba(0,0,0,0.18)}
.login-logo{text-align:center;margin-bottom:28px}
.login-logo .icon-big{font-size:48px;display:block;margin-bottom:8px}
.login-logo h1{font-size:22px;font-weight:700;color:var(--primary);margin-bottom:4px}
.login-logo p{font-size:13px;color:var(--text2)}
.role-tabs{display:flex;gap:8px;margin-bottom:24px;background:var(--bg);border-radius:8px;padding:4px}
.role-tab{flex:1;padding:8px;text-align:center;border-radius:6px;cursor:pointer;font-size:13px;font-weight:500;color:var(--text2);transition:.2s}
.role-tab.active{background:var(--primary);color:#fff}
.form-group{margin-bottom:16px}
.form-group label{display:block;font-size:13px;font-weight:500;color:var(--text2);margin-bottom:6px}
.form-group input{width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:8px;font-family:'Cairo',sans-serif;font-size:14px;color:var(--text);background:var(--surface);direction:ltr;transition:.2s}
.form-group input:focus{outline:none;border-color:var(--primary-light);box-shadow:0 0 0 3px rgba(37,99,168,0.12)}
.btn{display:inline-flex;align-items:center;gap:6px;padding:10px 20px;border-radius:8px;font-family:'Cairo',sans-serif;font-size:14px;font-weight:600;cursor:pointer;border:none;transition:.18s}
.btn-primary{background:var(--primary);color:#fff}
.btn-primary:hover{background:var(--primary-light)}
.btn-accent{background:var(--accent);color:#fff}
.btn-accent:hover{background:var(--accent-light);color:var(--text)}
.btn-danger{background:var(--danger);color:#fff}
.btn-success{background:var(--success);color:#fff}
.btn-ghost{background:transparent;color:var(--text2);border:1.5px solid var(--border)}
.btn-ghost:hover{background:var(--bg)}
.btn-sm{padding:6px 14px;font-size:12px}
.btn-block{width:100%;justify-content:center}
.login-error{color:var(--danger);font-size:12px;margin-top:8px;text-align:center}
.forgot-link{font-size:12px;color:var(--primary-light);cursor:pointer;text-align:center;margin-top:12px;text-decoration:underline}
#appPage{display:flex;flex-direction:column;min-height:100vh}
.topbar{background:var(--primary);color:#fff;padding:0 20px;height:56px;display:flex;align-items:center;gap:12px}
.topbar-logo{font-size:18px;font-weight:700;flex:1}
.topbar-user{font-size:13px;color:rgba(255,255,255,0.8)}
.topbar-btns{display:flex;gap:8px}
.topbar .btn{padding:6px 14px;font-size:12px}
.topbar .btn-ghost{color:#fff;border-color:rgba(255,255,255,0.35)}
.topbar .btn-ghost:hover{background:rgba(255,255,255,0.12)}
.app-body{display:flex;flex:1}
.sidebar{width:200px;background:var(--surface);border-left:1px solid var(--border);padding:16px 0;flex-shrink:0}
.nav-item{display:flex;align-items:center;gap:8px;padding:11px 20px;font-size:13px;font-weight:500;cursor:pointer;color:var(--text2);transition:.15s;border-right:3px solid transparent}
.nav-item:hover{background:var(--surface2);color:var(--primary)}
.nav-item.active{color:var(--primary);background:var(--surface2);border-right-color:var(--primary)}
.nav-icon{font-size:16px;width:20px;text-align:center}
.main-content{flex:1;padding:24px;overflow-y:auto}
.card{background:var(--surface);border-radius:var(--radius);border:1px solid var(--border);padding:20px;box-shadow:var(--shadow);margin-bottom:16px}
.card-title{font-size:16px;font-weight:700;color:var(--primary);margin-bottom:16px;display:flex;align-items:center;gap:8px}
.stat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:12px;margin-bottom:20px}
.stat-card{background:var(--surface2);border-radius:8px;padding:14px 16px;text-align:center}
.stat-num{font-size:26px;font-weight:700;color:var(--primary)}
.stat-lbl{font-size:11px;color:var(--text2);margin-top:2px}
.tbl{width:100%;border-collapse:collapse;font-size:13px}
.tbl th{background:var(--surface2);color:var(--text2);font-weight:600;padding:10px 12px;text-align:right;border-bottom:1px solid var(--border)}
.tbl td{padding:10px 12px;border-bottom:0.5px solid var(--border);color:var(--text);vertical-align:middle}
.tbl tr:hover td{background:var(--surface2)}
.badge{display:inline-block;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600}
.badge-success{background:#d4f0e1;color:#1a7a4a}
.badge-warn{background:#fef0d8;color:#b7600a}
.badge-danger{background:#fde8e6;color:#c0392b}
.badge-info{background:#daeeff;color:#1a5fa8}
.badge-gray{background:#eaecf2;color:#5a6480}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.form-group textarea{width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:8px;font-family:'Cairo',sans-serif;font-size:13px;resize:vertical;min-height:80px}
.form-group select{width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:8px;font-family:'Cairo',sans-serif;font-size:14px;background:var(--surface);color:var(--text)}
.modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,0.4);display:flex;align-items:center;justify-content:center;z-index:100}
.modal{background:var(--surface);border-radius:14px;padding:28px;width:500px;max-width:95vw;max-height:85vh;overflow-y:auto;box-shadow:0 16px 60px rgba(0,0,0,0.22)}
.modal-title{font-size:17px;font-weight:700;color:var(--primary);margin-bottom:20px}
.modal-footer{display:flex;gap:10px;justify-content:flex-end;margin-top:20px;border-top:1px solid var(--border);padding-top:16px}
.upload-area{border:2px dashed var(--border);border-radius:10px;padding:28px;text-align:center;cursor:pointer;transition:.2s;background:var(--surface2)}
.upload-area:hover{border-color:var(--primary-light);background:#e8f0ff}
.file-preview{background:var(--surface2);border-radius:8px;padding:10px 14px;margin-top:10px;font-size:13px;display:flex;align-items:center;justify-content:space-between}
.toast-wrap{position:fixed;bottom:20px;left:20px;z-index:999;display:flex;flex-direction:column;gap:8px}
.toast{padding:12px 20px;border-radius:10px;font-size:13px;font-weight:500;color:#fff;animation:slideUp .25s ease;min-width:220px}
.toast-success{background:var(--success)}.toast-error{background:var(--danger)}.toast-info{background:var(--primary-light)}
@keyframes slideUp{from{transform:translateY(20px);opacity:0}to{transform:translateY(0);opacity:1}}
.student-chip{display:inline-flex;align-items:center;gap:4px;background:#e8effe;border-radius:6px;padding:3px 8px;font-size:12px;color:var(--primary);margin:2px}
.notif-item{padding:14px 16px;border-bottom:0.5px solid var(--border);display:flex;gap:12px;cursor:pointer;transition:.15s}
.notif-item:hover{background:var(--surface2)}
.notif-item.unread{background:#edf3ff}
.notif-dot{width:8px;height:8px;border-radius:50%;background:var(--accent);margin-top:5px;flex-shrink:0}
.notif-dot.read{background:transparent}
.notif-title{font-size:13px;font-weight:600;color:var(--text)}
.notif-body{font-size:12px;color:var(--text2);margin-top:2px}
.notif-time{font-size:11px;color:var(--text3);margin-top:4px}
.assign-detail-row{display:flex;gap:8px;align-items:baseline;margin-bottom:8px;font-size:13px}
.assign-detail-lbl{color:var(--text2);min-width:90px;flex-shrink:0}
.assign-detail-val{color:var(--text);font-weight:500}
.loading-overlay{position:fixed;inset:0;background:rgba(255,255,255,0.7);display:flex;align-items:center;justify-content:center;z-index:200;font-size:18px;color:var(--primary);font-weight:700;backdrop-filter:blur(2px)}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px}
</style>
</head>
<body>
<div class="toast-wrap" id="toastWrap"></div>

<div id="loginPage" class="page">
  <div class="login-card">
    <div class="login-logo">
      <span class="icon-big">🎓</span>
      <h1>منصة تسليم الأبحاث</h1>
      <p>نظام إدارة الأبحاث والواجبات الأكاديمية</p>
    </div>
    <div class="role-tabs">
      <div class="role-tab active" onclick="setRole('student')">طالب</div>
      <div class="role-tab" onclick="setRole('admin')">مسؤول</div>
    </div>
    <div class="form-group">
      <label>الرقم القومي</label>
      <input type="text" id="loginId" placeholder="أدخل الرقم القومي" maxlength="14" />
    </div>
    <div class="form-group">
      <label>كلمة المرور (اختيارية للطلاب)</label>
      <input type="password" id="loginPass" placeholder="كلمة المرور" />
    </div>
    <div id="loginError" class="login-error hidden"></div>
    <br>
    <button class="btn btn-primary btn-block" onclick="doLogin()">دخول</button>
    <div class="forgot-link" onclick="showForgotModal()">نسيت كلمة المرور؟</div>
  </div>
</div>

<div id="appPage" class="page hidden">
  <div class="topbar">
    <div class="topbar-logo">🎓 منصة تسليم الأبحاث</div>
    <div class="topbar-user" id="topbarUser"></div>
    <div class="topbar-btns">
      <button class="btn btn-ghost btn-sm" onclick="showChangePassModal()">تغيير كلمة المرور</button>
      <button class="btn btn-ghost btn-sm" onclick="logout()">خروج</button>
    </div>
  </div>
  <div class="app-body">
    <div class="sidebar" id="sidebar"></div>
    <div class="main-content" id="mainContent"><div style="text-align:center;padding:40px;color:var(--text2)">جاري التحميل...</div></div>
  </div>
</div>

<div id="modalBackdrop" class="modal-backdrop hidden" onclick="closeModal(event)">
  <div class="modal" id="modalBox" onclick="event.stopPropagation()">
    <div id="modalContent"></div>
  </div>
</div>

<script>
// ═══════════════════════════════════════════
//  ضع بياناتك هنا
const SUPABASE_URL = 'https://jivyhhdexcvxpjlujgpz.supabase.co';
const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImppdnloaGRleGN2eHBqbHVqZ3B6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY0NjYxMjQsImV4cCI6MjA5MjA0MjEyNH0.QSehBWvhFeZIDha4FL222VShEjHEAcoqE2dVy-auhLs';
// ═══════════════════════════════════════════

async function sb(table, method='GET', body=null, query=''){
  const url=`${SUPABASE_URL}/rest/v1/${table}${query}`;
  const opts={method,headers:{'Content-Type':'application/json','apikey':SUPABASE_KEY,'Authorization':'Bearer '+SUPABASE_KEY,'Prefer':'return=representation'}};
  if(body)opts.body=JSON.stringify(body);
  const r=await fetch(url,opts);
  if(!r.ok){const e=await r.text();throw new Error(e);}
  const ct=r.headers.get('content-type')||'';
  if(ct.includes('json')&&r.status!==204)return r.json();
  return [];
}
const DB={
  async get(table,query=''){return sb(table,'GET',null,query);},
  async insert(table,row){return sb(table,'POST',row);},
  async update(table,query,data){return sb(table,'PATCH',data,query);},
  async delete(table,query){return sb(table,'DELETE',null,query);}
};

function loading(show){
  let el=document.getElementById('loadingOverlay');
  if(show){if(!el){el=document.createElement('div');el.id='loadingOverlay';el.className='loading-overlay';el.textContent='⏳ جاري التحميل...';document.body.appendChild(el);}}
  else{if(el)el.remove();}
}

let currentUser=null,currentRole=null,loginRole='student';

function setRole(r){
  loginRole=r;
  document.querySelectorAll('.role-tab').forEach((t,i)=>t.classList.toggle('active',i===(r==='student'?0:1)));
}

async function doLogin(){
  const id=document.getElementById('loginId').value.trim();
  const pass=document.getElementById('loginPass').value;
  const errEl=document.getElementById('loginError');
  errEl.classList.add('hidden');
  if(!id){errEl.textContent='أدخل الرقم القومي';errEl.classList.remove('hidden');return;}
  loading(true);
  try{
    if(loginRole==='admin'){
      const rows=await DB.get('admin',`?id=eq.${id}`);
      if(!rows.length||rows[0].pass!==pass){errEl.textContent='بيانات المسؤول غير صحيحة';errEl.classList.remove('hidden');loading(false);return;}
      currentUser=rows[0];currentRole='admin';
    } else {
      const rows=await DB.get('students',`?id=eq.${id}`);
      if(!rows.length){errEl.textContent='الرقم القومي غير مسجل';errEl.classList.remove('hidden');loading(false);return;}
      const st=rows[0];
      if(st.pass&&pass!==st.pass&&pass!==''){errEl.textContent='كلمة المرور غير صحيحة';errEl.classList.remove('hidden');loading(false);return;}
      currentUser=st;currentRole='student';
    }
    document.getElementById('loginPage').classList.add('hidden');
    document.getElementById('appPage').classList.remove('hidden');
    document.getElementById('topbarUser').textContent=(currentRole==='admin'?'المسؤول: ':'طالب: ')+(currentUser.name||currentUser.id);
    buildSidebar();
    navigate(currentRole==='admin'?'dashboard':'myAssignments');
  }catch(e){errEl.textContent='خطأ في الاتصال بالخادم';errEl.classList.remove('hidden');}
  loading(false);
}

function logout(){
  currentUser=null;currentRole=null;
  document.getElementById('appPage').classList.add('hidden');
  document.getElementById('loginPage').classList.remove('hidden');
  document.getElementById('loginId').value='';
  document.getElementById('loginPass').value='';
}

function buildSidebar(){
  const sidebar=document.getElementById('sidebar');
  const adminNav=[
    {id:'dashboard',icon:'📊',label:'لوحة التحكم'},
    {id:'courses',icon:'📚',label:'المقررات'},
    {id:'assignments',icon:'📝',label:'طلبات التسليم'},
    {id:'submissions',icon:'📥',label:'التسليمات'},
    {id:'students',icon:'👥',label:'الطلاب'},
    {id:'settings',icon:'⚙️',label:'الإعدادات'},
  ];
  const studentNav=[
    {id:'myAssignments',icon:'📝',label:'طلبات التسليم'},
    {id:'mySubmissions',icon:'📁',label:'تسليماتي'},
    {id:'notifications',icon:'🔔',label:'الإشعارات'},
    {id:'profile',icon:'👤',label:'حسابي'},
  ];
  const nav=currentRole==='admin'?adminNav:studentNav;
  sidebar.innerHTML=nav.map(n=>`<div class="nav-item" id="nav-${n.id}" onclick="navigate('${n.id}')"><span class="nav-icon">${n.icon}</span>${n.label}</div>`).join('');
}

async function navigate(page){
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  const el=document.getElementById('nav-'+page);if(el)el.classList.add('active');
  const mc=document.getElementById('mainContent');
  mc.innerHTML='<div style="text-align:center;padding:40px;color:var(--text2)">⏳ جاري التحميل...</div>';
  loading(true);
  try{
    const pages={
      dashboard:renderAdminDashboard,courses:renderCourses,
      assignments:renderAssignments,submissions:renderAdminSubmissions,
      students:renderStudents,settings:renderSettings,
      myAssignments:renderStudentAssignments,mySubmissions:renderStudentSubmissions,
      notifications:renderNotifications,profile:renderProfile,
    };
    if(pages[page])mc.innerHTML=await pages[page]();
    else mc.innerHTML='<div class="card">قريباً</div>';
  }catch(e){mc.innerHTML='<div class="card" style="color:var(--danger)">خطأ في تحميل البيانات</div>';}
  loading(false);
}

async function renderAdminDashboard(){
  const [courses,students,assignments,submissions]=await Promise.all([
    DB.get('courses'),DB.get('students'),DB.get('assignments'),DB.get('submissions')
  ]);
  const pending=submissions.filter(s=>s.status==='pending').length;
  return `<div class="stat-grid">
    <div class="stat-card"><div class="stat-num">${courses.length}</div><div class="stat-lbl">المقررات</div></div>
    <div class="stat-card"><div class="stat-num">${students.length}</div><div class="stat-lbl">الطلاب</div></div>
    <div class="stat-card"><div class="stat-num">${assignments.length}</div><div class="stat-lbl">طلبات التسليم</div></div>
    <div class="stat-card"><div class="stat-num">${pending}</div><div class="stat-lbl">بانتظار المراجعة</div></div>
  </div>
  <div class="card"><div class="card-title">📋 آخر التسليمات</div>
  ${renderSubmissionsTable(submissions.slice(-5).reverse(),true,students,assignments)}</div>`;
}

async function renderCourses(){
  const courses=await DB.get('courses');
  return `<div class="card"><div class="card-title">📚 المقررات <button class="btn btn-primary btn-sm" style="margin-right:auto" onclick="showAddCourseModal()">+ إضافة مقرر</button></div>
    ${courses.length===0?'<p style="color:var(--text2);text-align:center;padding:20px">لا توجد مقررات بعد</p>':''}
    <div style="display:grid;gap:12px">${courses.map(c=>`
      <div class="card" style="margin:0;padding:16px"><div style="display:flex;align-items:center;gap:10px">
        <div style="flex:1"><div style="font-weight:700;font-size:15px;color:var(--primary)">${c.name}</div>
        <div style="font-size:12px;color:var(--text2);margin-top:3px">${c.code||''} · ${(c.students||[]).length} طالب · ${(c.groups||[]).length} مجموعة</div></div>
        <button class="btn btn-ghost btn-sm" onclick="showCourseDetail('${c.id}')">تفاصيل</button>
        <button class="btn btn-danger btn-sm" onclick="deleteCourse('${c.id}')">حذف</button>
      </div></div>`).join('')}</div></div>`;
}

async function renderStudents(){
  const students=await DB.get('students');
  return `<div class="card"><div class="card-title">👥 الطلاب <button class="btn btn-primary btn-sm" style="margin-right:auto" onclick="showAddStudentModal()">+ إضافة طالب</button></div>
    <table class="tbl"><thead><tr><th>الاسم</th><th>الرقم القومي</th><th>البريد</th><th>كلمة المرور</th><th>إجراءات</th></tr></thead>
    <tbody>${students.map(s=>`<tr>
      <td>${s.name}</td><td style="direction:ltr;text-align:right">${s.id}</td>
      <td>${s.email||'—'}</td>
      <td><span class="badge badge-${s.pass?'success':'gray'}">${s.pass?'مضبوطة':'بدون'}</span></td>
      <td style="display:flex;gap:4px"><button class="btn btn-ghost btn-sm" onclick="showEditStudentModal('${s.id}')">تعديل</button>
      <button class="btn btn-danger btn-sm" onclick="deleteStudent('${s.id}')">حذف</button></td>
    </tr>`).join('')||'<tr><td colspan="5" style="text-align:center;color:var(--text2);padding:20px">لا يوجد طلاب</td></tr>'}
    </tbody></table></div>`;
}

async function renderAssignments(){
  const [assignments,courses,submissions]=await Promise.all([
    DB.get('assignments'),DB.get('courses'),DB.get('submissions')
  ]);
  return `<div class="card"><div class="card-title">📝 طلبات التسليم <button class="btn btn-primary btn-sm" style="margin-right:auto" onclick="showAddAssignmentModal()">+ إنشاء طلب</button></div>
    ${assignments.length===0?'<p style="text-align:center;color:var(--text2);padding:20px">لا توجد طلبات بعد</p>':''}
    <div style="display:grid;gap:10px">${assignments.map(a=>{
      const c=courses.find(x=>x.id===a.course_id);
      const subs=submissions.filter(s=>s.assignment_id===a.id);
      return `<div class="card" style="margin:0;padding:14px"><div style="display:flex;align-items:flex-start;gap:10px">
        <div style="flex:1"><div style="font-weight:700;font-size:14px">${a.title}</div>
        <div style="font-size:12px;color:var(--text2);margin-top:3px">${c?c.name:'—'} · ${a.target_type==='all'?'جميع الطلاب':'مجموعة: '+a.target_group} · الموعد: ${a.deadline||'مفتوح'}</div>
        <div style="margin-top:6px;font-size:12px;color:var(--text2)">${subs.length} تسليم</div></div>
        <span class="badge badge-${a.status==='open'?'success':'gray'}">${a.status==='open'?'مفتوح':'مغلق'}</span>
        <button class="btn btn-ghost btn-sm" onclick="toggleAssignmentStatus('${a.id}','${a.status}')">${a.status==='open'?'إغلاق':'فتح'}</button>
        <button class="btn btn-danger btn-sm" onclick="deleteAssignment('${a.id}')">حذف</button>
