  const rows=await DB.get('courses',`?id=eq.${cid}`);const c=rows[0];
  const arr=c.students||[];if(!arr.includes(sid))arr.push(sid);
  await DB.update('courses',`?id=eq.${cid}`,{students:arr});
  loading(false);toast('تم إضافة الطالب','success');showCourseDetail(cid);
}

async function removeStudentFromCourse(cid,sid){
  loading(true);
  const rows=await DB.get('courses',`?id=eq.${cid}`);const c=rows[0];
  c.students=(c.students||[]).filter(x=>x!==sid);
  c.groups=(c.groups||[]).map(g=>({...g,members:(g.members||[]).filter(x=>x!==sid)}));
  await DB.update('courses',`?id=eq.${cid}`,{students:c.students,groups:c.groups});
  loading(false);toast('تم الإزالة','success');showCourseDetail(cid);
}

